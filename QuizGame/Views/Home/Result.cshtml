@model QuizGame.Models.Api.AnswerResultDto

@{
    ViewData["Title"] = "Resultado";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card">

                @if (Model.Status == "Winner")
                {
                    <div class="result-banner banner-winner">
                        <div class="confetti-row">
                            <div class="confetti-dot"></div>
                            <div class="confetti-dot"></div>
                            <div class="confetti-dot"></div>
                            <div class="confetti-dot"></div>
                            <div class="confetti-dot"></div>
                        </div>
                        <div class="result-icon-wrap" style="border:2px solid rgba(245,166,35,0.4);">
                            <i class="ti ti-trophy" style="color:var(--ciel-accent);font-size:32px;"></i>
                        </div>
                        <h2 class="fw-bold mb-1">¡Ganaste el juego!</h2>
                        <p style="color:rgba(255,255,255,0.7);font-size:14px;">Completaste los 5 niveles — eres el campeón</p>
                    </div>
                    <div class="card-body p-4">
                        <div class="winner-prize-box">
                            <p class="winner-prize-label">Premio mayor</p>
                            <p class="winner-prize-value">$@Model.AccumulatedPrize.ToString("N0")</p>
                            <p class="winner-prize-sub">5 niveles · 5 respuestas correctas</p>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <div class="result-stat">
                                    <p class="result-stat-label">Niveles completados</p>
                                    <p class="result-stat-value">@Model.CurrentLevel / 5</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="result-stat">
                                    <p class="result-stat-label">Estado</p>
                                    <p class="result-stat-value" style="color:var(--ciel-success);">Ganador</p>
                                </div>
                            </div>
                        </div>
                        <div class="d-grid">
                            <a asp-action="Index" class="btn btn-ciel btn-lg">
                                <i class="ti ti-refresh me-2"></i>Jugar de nuevo
                            </a>
                        </div>
                    </div>
                }
                else if (Model.Status == "Withdrawn")
                {
                    <div class="result-banner banner-primary">
                        <div class="result-icon-wrap">
                            <i class="ti ti-logout" style="font-size:28px;color:var(--ciel-cyan);"></i>
                        </div>
                        <h2 class="fw-bold mb-1">Te retiraste del juego</h2>
                        <p style="color:rgba(255,255,255,0.7);font-size:14px;">Tomaste la decisión correcta — conservas tu premio</p>
                    </div>
                    <div class="card-body p-4">
                        <div class="result-prize-box" style="background:#F0F5FF;border:1.5px solid #D0DCF0;">
                            <p class="result-prize-label">Te llevas</p>
                            <p class="result-prize-value" style="color:var(--ciel-primary);">
                                $@Model.AccumulatedPrize.ToString("N0")
                            </p>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <div class="result-stat">
                                    <p class="result-stat-label">Nivel alcanzado</p>
                                    <p class="result-stat-value">@Model.CurrentLevel / 5</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="result-stat">
                                    <p class="result-stat-label">Estado</p>
                                    <p class="result-stat-value" style="color:var(--ciel-blue);">Retirado</p>
                                </div>
                            </div>
                        </div>
                        <div class="d-grid">
                            <a asp-action="Index" class="btn btn-ciel btn-lg">
                                <i class="ti ti-home me-2"></i>Volver al inicio
                            </a>
                        </div>
                    </div>
                }
                else if (Model.Status == "Lost")
                {
                    <div class="result-banner banner-danger">
                        <div class="result-icon-wrap">
                            <i class="ti ti-circle-x" style="font-size:30px;color:#fff;"></i>
                        </div>
                        <h2 class="fw-bold mb-1">Respuesta incorrecta</h2>
                        <p style="color:rgba(255,255,255,0.7);font-size:14px;">Sales del juego sin tu acumulado</p>
                    </div>
                    <div class="card-body p-4">

                        @* Comparación tu respuesta vs correcta *@
                        @if (!string.IsNullOrEmpty(Model.SelectedOptionText) || !string.IsNullOrEmpty(Model.CorrectOptionText))
                        {
                            <div class="mb-3 p-3" style="background:#FDF4F3;border:1px solid #F7C1C1;border-radius:12px;">
                                @if (!string.IsNullOrEmpty(Model.SelectedOptionText))
                                {
                                    <p style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ciel-danger);margin-bottom:8px;">Tu respuesta</p>
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <span style="width:28px;height:28px;border-radius:7px;background:var(--ciel-danger);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="ti ti-x" style="font-size:14px;"></i>
                                        </span>
                                        <span style="font-size:15px;font-weight:500;color:var(--ciel-danger);">@Model.SelectedOptionText</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.CorrectOptionText))
                                {
                                    <hr style="border-color:#F7C1C1;margin:0.5rem 0 0.75rem;" />
                                    <p style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ciel-success);margin-bottom:8px;">Respuesta correcta</p>
                                    <div class="d-flex align-items-center gap-2">
                                        <span style="width:28px;height:28px;border-radius:7px;background:var(--ciel-success);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="ti ti-check" style="font-size:14px;"></i>
                                        </span>
                                        <span style="font-size:15px;font-weight:500;color:var(--ciel-success);">@Model.CorrectOptionText</span>
                                    </div>
                                }
                            </div>
                        }

                        <div class="d-flex align-items-center justify-content-between mb-3 p-3"
                             style="background:#FDF4F3;border:1px solid #F7C1C1;border-radius:12px;">
                            <div>
                                <p class="result-prize-label">Acumulado perdido</p>
                                <p class="result-prize-value" style="font-size:28px;color:var(--ciel-danger);text-decoration:line-through;opacity:0.7;">
                                    $@Model.AccumulatedPrize.ToString("N0")
                                </p>
                            </div>
                            <i class="ti ti-lock" style="font-size:28px;color:#F0B8B8;"></i>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <div class="result-stat">
                                    <p class="result-stat-label">Nivel alcanzado</p>
                                    <p class="result-stat-value">@Model.CurrentLevel / 5</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="result-stat">
                                    <p class="result-stat-label">Estado</p>
                                    <p class="result-stat-value" style="color:var(--ciel-danger);">Eliminado</p>
                                </div>
                            </div>
                        </div>
                        <p class="text-center mb-4" style="font-size:13px;color:var(--ciel-muted);">
                            Llegaste al nivel @Model.CurrentLevel. ¡Inténtalo de nuevo!
                        </p>
                        <div class="d-grid">
                            <a asp-action="Index" class="btn btn-ciel btn-lg">
                                <i class="ti ti-home me-2"></i>Volver al inicio
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    @* InProgress: respuesta correcta, muestra feedback antes de continuar *@
                    <div class="result-banner banner-success" style="padding:1.5rem 2rem;">
                        <div class="result-icon-wrap">
                            <i class="ti ti-circle-check" style="font-size:30px;color:#fff;"></i>
                        </div>
                        <h2 class="fw-bold mb-1">¡Respuesta correcta!</h2>
                        <p style="color:rgba(255,255,255,0.75);font-size:14px;">Avanzas al siguiente nivel</p>
                    </div>
                    <div class="card-body p-3">
                        @if (!string.IsNullOrEmpty(Model.SelectedOptionText))
                        {
                            <div class="d-flex align-items-center gap-3 mb-3 p-3"
                                 style="background:#E6FAF5;border:1.5px solid #0A9272;border-radius:12px;">
                                <span style="width:32px;height:32px;border-radius:8px;background:var(--ciel-success);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                    <i class="ti ti-check" style="font-size:16px;"></i>
                                </span>
                                <span style="font-size:15px;font-weight:600;color:#065C47;">@Model.SelectedOptionText</span>
                            </div>
                        }
                        <div style="background:#F0F5FF;border:1.5px solid #D0DCF0;border-radius:12px;padding:0.75rem 1rem;text-align:center;margin-bottom:0.75rem;">
                            <p style="font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--ciel-muted);margin:0 0 2px;">Acumulado total</p>
                            <p style="font-size:28px;font-weight:700;font-family:var(--ciel-mono);color:var(--ciel-primary);margin:0;">$@Model.AccumulatedPrize.ToString("N0")</p>
                            <p style="font-size:12px;color:var(--ciel-muted);margin:2px 0 0;">@Model.Message</p>
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="result-stat">
                                    <p class="result-stat-label">Nivel completado</p>
                                    <p class="result-stat-value">@(Model.CurrentLevel - 1) / 5</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="result-stat">
                                    <p class="result-stat-label">Siguiente nivel</p>
                                    <p class="result-stat-value" style="color:var(--ciel-success);">@Model.CurrentLevel</p>
                                </div>
                            </div>
                        </div>
                        <div class="d-grid">
                            <a asp-action="Question"
                               asp-route-gameId="@Context.Session.GetInt32("GameId")"
                               class="btn btn-ciel btn-lg">
                                <i class="ti ti-arrow-right me-2"></i>Continuar al Nivel @(Model.CurrentLevel)
                            </a>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</div>
